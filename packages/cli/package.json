{
  "name": "@app-builder/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "app-builder": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@app-builder/core": "workspace:*",
    "@vercel/sandbox": "^1.6.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "eslint": "^9.20.0",
    "tsx": "^4.19.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  }
}
